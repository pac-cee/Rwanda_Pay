# ── Rwanda Pay — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_PORT=8080

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=rwandapay
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=rwanda_pay

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Change this in production!
JWT_SECRET=rwanda-pay-jwt-secret-change-in-production-min-32-chars
JWT_EXPIRY_HOURS=168         # 7 days

# ── AES-256-GCM Encryption (for card numbers) ─────────────────────────────────
# Must be exactly 32 bytes encoded as hex (64 hex chars).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=6368616e676520746869732070617373776f726420746f206120736563726574

# ── Mobile App ────────────────────────────────────────────────────────────────
# Set to your machine's IP or domain when running on a physical device.
# Example: EXPO_PUBLIC_DOMAIN=192.168.1.10:8080
EXPO_PUBLIC_DOMAIN=localhost:8080
